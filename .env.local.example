# Copy to .env.local and fill in. Never commit .env.local.

# Where the FastAPI backend (token-budget-proxy) is running
BACKEND_URL=http://localhost:8000

# Must match the backend's ADMIN_PASSWORD
ADMIN_PASSWORD=change-me

# Secret used to encrypt the session cookie (>= 32 characters)
SESSION_SECRET=please-change-this-to-a-long-random-string-32b
